extends ../partials/admin-layout

block body
  .two-col-layout
    .card.form-card
      .card-header
        h2 Add Class
        i.fas.fa-plus
      .card-body
        form(method='POST', action='/admin/classes')
          .form-group
            label Class Name
            input(type='text', name='name', required, placeholder='e.g. Grade 1, Form 3A')
          .form-group
            label Department
            select(name='departmentId', required)
              option(value='') Select department
              each dept in departments
                option(value=dept.id) #{dept.name} (#{dept.code})
          button.btn.btn-primary(type='submit')
            i.fas.fa-save
            span Save Class

    .card
      .card-header
        h2 All Classes
        span.count-badge #{pagination.total}
      .card-body
        if classes.length
          table.data-table
            thead
              tr
                th Name
                th Department
                th Streams
                th Students
                th Actions
            tbody
              each cls in classes
                tr(id='cls-row-'+cls.id)
                  td.editable-cell
                    span.display-val
                      span.badge.badge-class #{cls.name}
                    input.edit-input(type='text', value=cls.name, name='name', style='display:none')
                  td.editable-cell
                    span.display-val #{cls.department ? cls.department.code : '-'}
                    select.edit-input(name='departmentId', style='display:none')
                      each dept in departments
                        option(value=dept.id, selected=cls.departmentId==dept.id) #{dept.name}
                  td #{cls.streams ? cls.streams.length : 0}
                  td #{cls.students ? cls.students.length : 0}
                  td
                    .action-group
                      button.btn.btn-sm.btn-outline.edit-btn(type='button', data-id=cls.id, data-prefix='cls')
                        i.fas.fa-edit
                        span Edit
                      form.save-form(method='POST', action=`/admin/classes/${cls.id}/edit`, style='display:none', data-id=cls.id, data-prefix='cls')
                        button.btn.btn-sm.btn-primary(type='submit')
                          i.fas.fa-check
                          span Save
                        button.btn.btn-sm.btn-outline.cancel-btn(type='button', data-id=cls.id, data-prefix='cls')
                          i.fas.fa-times
                      form(method='POST', action=`/admin/classes/${cls.id}/delete`, style='display:inline')
                        button.btn.btn-danger.btn-sm(type='submit', onclick='return confirm("Delete this class?")')
                          i.fas.fa-trash
        else
          .empty-state
            i.fas.fa-door-open
            p No classes added yet.

        if pagination && pagination.pages > 1
          - const query = {}
          include ../partials/pagination

  script.
    function setupInlineEdit(prefix, rowPrefix) {
      document.querySelectorAll('[data-prefix="' + prefix + '"].edit-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          const id = this.dataset.id;
          const row = document.getElementById(rowPrefix + '-row-' + id);
          row.querySelectorAll('.display-val').forEach(function(el) { el.style.display = 'none'; });
          row.querySelectorAll('.edit-input').forEach(function(el) { el.style.display = 'inline-block'; });
          this.style.display = 'none';
          const saveForm = row.querySelector('.save-form');
          saveForm.style.display = 'inline-flex';
          row.querySelectorAll('.edit-input').forEach(function(inp) { saveForm.insertBefore(inp, saveForm.firstChild); });
        });
      });
      document.querySelectorAll('[data-prefix="' + prefix + '"].cancel-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          const id = this.dataset.id;
          const row = document.getElementById(rowPrefix + '-row-' + id);
          row.querySelectorAll('.display-val').forEach(function(el) { el.style.display = ''; });
          row.querySelectorAll('.edit-input').forEach(function(el) { el.style.display = 'none'; });
          row.querySelector('[data-prefix="' + prefix + '"].edit-btn').style.display = '';
          row.querySelector('.save-form').style.display = 'none';
        });
      });
    }
    setupInlineEdit('cls', 'cls');
