extends ../partials/admin-layout

block body
  .two-col-layout
    .card.form-card
      .card-header
        h2 Assign Teacher to Class
        i.fas.fa-link
      .card-body
        form(method='POST', action='/admin/assignments/teacher-class')
          .form-group
            label Select Teacher
            select(name='teacherId', required)
              option(value='') Choose teacher
              each teacher in (teachers || [])
                option(value=teacher.id) #{teacher.fullName} (#{teacher.department ? teacher.department.code : ''})

          .form-group
            label
              span.step-badge 1
              | Department
            select(id='formDeptSel', required)
              option(value='') Select department
              each dept in (departments || [])
                option(value=dept.id) #{dept.name} (#{dept.code})

          .form-group
            label
              span.step-badge 2
              | Class
            select(name='classIds', id='formClassSel', required)
              option(value='') — select department first —

          .form-group
            label Set as Class Teacher?
            select(name='classTeacherId', id='ctSel')
              option(value='') — No (regular teacher) —
            .form-hint
              i.fas.fa-info-circle
              span Select the class above to set as class teacher. Only one class teacher allowed per class.

          button.btn.btn-primary(type='submit')
            i.fas.fa-link
            span Assign

    .card
      .card-header
        h2 Filter Assignments
        i.fas.fa-filter
      .card-body
        form.filter-form(method='GET', action='/admin/assignments/teacher-class')
          .form-row
            .form-group
              label Department
              select(name='deptId', id='filterDeptSel')
                option(value='') All Departments
                each dept in (departments || [])
                  option(value=dept.id, selected=selectedDeptId==dept.id.toString()) #{dept.name} (#{dept.code})
            .form-group
              label Class
              select(name='classId', id='filterClassSel')
                option(value='') All Classes
                if selectedDeptId && filteredClasses.length
                  each cls in (filteredClasses || [])
                    option(value=cls.id, selected=selectedClassId==cls.id.toString()) #{cls.name}
            button.btn.btn-primary(type='submit')
              i.fas.fa-search
              span Filter

      .card-header(style='border-top:1px solid var(--border)')
        h2 Current Assignments
        span.count-badge #{pagination.total}
      .card-body
        if assignments.length
          table.data-table
            thead
              tr
                th Teacher
                th Class
                th Department
                th Role
                th Actions
            tbody
              each a in (assignments || [])
                tr
                  td
                    .teacher-name
                      i.fas.fa-user-circle
                      span #{a.teacher ? a.teacher.fullName : '-'}
                  td
                    span.badge.badge-class #{a.class ? a.class.name : '-'}
                  td
                    if a.class && a.class.department
                      span(class=`dept-badge badge-${a.class.department.code.toLowerCase()}`) #{a.class.department.code}
                    else
                      | -
                  td
                    if a.isClassTeacher
                      span.role-badge.role-class_teacher CLASS TEACHER
                    else
                      span.text-muted Teacher
                  td
                    .action-group
                      if a.isClassTeacher
                        form(method='POST', action=`/admin/assignments/teacher-class/${a.id}/unset-class-teacher`, style='display:inline')
                          button.btn.btn-sm.btn-warning(type='submit')
                            i.fas.fa-user-minus
                            span Unset CT
                      else
                        form(method='POST', action=`/admin/assignments/teacher-class/${a.id}/set-class-teacher`, style='display:inline')
                          button.btn.btn-sm.btn-outline(type='submit')
                            i.fas.fa-chalkboard-teacher
                            span Set CT
                      form(method='POST', action=`/admin/assignments/teacher-class/${a.id}/remove`, style='display:inline')
                        button.btn.btn-danger.btn-sm(type='submit', onclick='return confirm("Remove this assignment?")')
                          i.fas.fa-unlink
        else
          .empty-state
            i.fas.fa-link
            p No assignments found.

        if pagination.pages > 1
          - const query = {deptId: selectedDeptId, classId: selectedClassId}
          include ../partials/pagination

  script.
    const deptClassMap = !{JSON.stringify(deptClassMap)};

    // ── Form cascade: Dept → Class → CT select ──────────────────────────────
    const formDeptSel  = document.getElementById('formDeptSel');
    const formClassSel = document.getElementById('formClassSel');
    const ctSel        = document.getElementById('ctSel');

    function updateFormClasses() {
      const did = formDeptSel.value;
      const classes = deptClassMap[did] || [];
      formClassSel.innerHTML = '<option value="">— select class —</option>';
      classes.forEach(function(c) {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = c.name;
        formClassSel.appendChild(opt);
      });
      updateCtSelect();
    }

    function updateCtSelect() {
      const cid = formClassSel.value;
      const text = formClassSel.options[formClassSel.selectedIndex]
        ? formClassSel.options[formClassSel.selectedIndex].text : '';
      ctSel.innerHTML = '<option value="">— No (regular teacher) —</option>';
      if (cid) {
        const opt = document.createElement('option');
        opt.value = cid;
        opt.textContent = 'Yes — Class Teacher of ' + text;
        ctSel.appendChild(opt);
      }
    }

    formDeptSel.addEventListener('change', updateFormClasses);
    formClassSel.addEventListener('change', updateCtSelect);

    // ── Filter cascade: Dept → Class ────────────────────────────────────────
    const filterDeptSel  = document.getElementById('filterDeptSel');
    const filterClassSel = document.getElementById('filterClassSel');
    const savedDept  = '!{selectedDeptId}';
    const savedClass = '!{selectedClassId}';

    function updateFilterClasses() {
      const did = filterDeptSel.value;
      const classes = deptClassMap[did] || [];
      filterClassSel.innerHTML = '<option value="">All Classes</option>';
      classes.forEach(function(c) {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = c.name;
        if (String(c.id) === savedClass) opt.selected = true;
        filterClassSel.appendChild(opt);
      });
    }

    filterDeptSel.addEventListener('change', updateFilterClasses);
    if (filterDeptSel.value) updateFilterClasses();
