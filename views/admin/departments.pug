extends ../partials/admin-layout

block body
  .two-col-layout
    .card.form-card
      .card-header
        h2 Add Department
        i.fas.fa-plus
      .card-body
        form(method='POST', action='/admin/departments')
          .form-group
            label Department Name
            input(type='text', name='name', required, placeholder='e.g. Early Years Centre')
          .form-group
            label Department Code
            select(name='code', required)
              option(value='') Select code
              option(value='EYC') EYC — Early Years Centre
              option(value='Primary') Primary
              option(value='Secondary') Secondary
          button.btn.btn-primary(type='submit')
            i.fas.fa-save
            span Save Department

    .card
      .card-header
        h2 All Departments
        span.count-badge #{pagination.total}
      .card-body
        if departments.length
          table.data-table
            thead
              tr
                th # 
                th Name
                th Code
                th Classes
                th Teachers
                th Actions
            tbody
              each dept, i in departments
                tr(id='dept-row-'+dept.id)
                  td #{i+1}
                  td.editable-cell
                    span.display-val #{dept.name}
                    input.edit-input(type='text', value=dept.name, name='name', style='display:none')
                  td.editable-cell
                    span.display-val #{dept.code}
                    select.edit-input(name='code', style='display:none')
                      option(value='EYC', selected=dept.code==='EYC') EYC
                      option(value='Primary', selected=dept.code==='Primary') Primary
                      option(value='Secondary', selected=dept.code==='Secondary') Secondary
                  td #{dept.classes ? dept.classes.length : 0}
                  td #{dept.teachers ? dept.teachers.length : 0}
                  td
                    .action-group
                      button.btn.btn-sm.btn-outline.edit-btn(type='button', data-id=dept.id)
                        i.fas.fa-edit
                        span Edit
                      form.save-form(method='POST', action=`/admin/departments/${dept.id}/edit`, style='display:none', data-id=dept.id)
                        button.btn.btn-sm.btn-primary(type='submit')
                          i.fas.fa-check
                          span Save
                        button.btn.btn-sm.btn-outline.cancel-btn(type='button', data-id=dept.id)
                          i.fas.fa-times
                      form(method='POST', action=`/admin/departments/${dept.id}/delete`, style='display:inline')
                        button.btn.btn-danger.btn-sm(type='submit', onclick='return confirm("Delete this department?")')
                          i.fas.fa-trash
        else
          .empty-state
            i.fas.fa-building
            p No departments added yet.

        if pagination && pagination.pages > 1
          - const query = {}
          include ../partials/pagination

  script.
    document.querySelectorAll('.edit-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        const id = this.dataset.id;
        const row = document.getElementById('dept-row-' + id);
        row.querySelectorAll('.display-val').forEach(function(el) { el.style.display = 'none'; });
        row.querySelectorAll('.edit-input').forEach(function(el) {
          el.style.display = 'inline-block';
          el.name = el.name; // keep name for form submission
        });
        this.style.display = 'none';
        const saveForm = row.querySelector('.save-form');
        saveForm.style.display = 'inline-flex';
        // Move inputs inside save form so they submit
        const inputs = row.querySelectorAll('.edit-input');
        inputs.forEach(function(inp) { saveForm.insertBefore(inp, saveForm.firstChild); });
      });
    });
    document.querySelectorAll('.cancel-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        const id = this.dataset.id;
        const row = document.getElementById('dept-row-' + id);
        row.querySelectorAll('.display-val').forEach(function(el) { el.style.display = ''; });
        row.querySelectorAll('.edit-input').forEach(function(el) { el.style.display = 'none'; });
        row.querySelector('.edit-btn').style.display = '';
        row.querySelector('.save-form').style.display = 'none';
      });
    });
