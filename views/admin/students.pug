extends ../partials/admin-layout

block body
  .two-col-layout
    .card.form-card
      .card-header
        h2 Add Student
        i.fas.fa-user-plus
      .card-body
        form(method='POST', action='/admin/students')
          .form-group
            label Full Name
            input(type='text', name='fullName', required, placeholder='Student full name')
          .form-group
            label Gender
            select(name='gender', required)
              option(value='') Select gender
              option(value='Male') Male
              option(value='Female') Female
          .form-group
            label
              span.step-badge 1
              | Department
            select(id='formDeptSel', required)
              option(value='') Select department
              each dept in (departments || [])
                option(value=dept.id) #{dept.name} (#{dept.code})
          .form-group
            label
              span.step-badge 2
              | Class
            select(name='classId', id='formClassSel', required)
              option(value='') — select department first —
          .form-group
            label
              span.step-badge 3
              | Stream (Optional)
            select(name='streamId', id='formStreamSel')
              option(value='') — no stream —
          button.btn.btn-primary(type='submit')
            i.fas.fa-save
            span Add Student

    .card
      .card-header
        h2 Filter Students
        i.fas.fa-filter
      .card-body
        form.filter-form(method='GET', action='/admin/students')
          .form-row
            .form-group
              label Department
              select(name='deptId', id='filterDeptSel')
                option(value='') All Departments
                each dept in (departments || [])
                  option(value=dept.id, selected=selectedDeptId==dept.id.toString()) #{dept.name} (#{dept.code})
            .form-group
              label Class
              select(name='classId', id='filterClassSel')
                option(value='') All Classes
                if selectedDeptId
                  each cls in (allClasses || [])
                    if String(cls.departmentId) == String(selectedDeptId)
                      option(value=cls.id, selected=String(selectedClassId)==String(cls.id)) #{cls.name}
            button.btn.btn-primary(type='submit')
              i.fas.fa-search
              span Filter
            if selectedDeptId || selectedClassId
              a.btn.btn-outline(href='/admin/students') Clear

      .card-header(style='border-top:1px solid var(--border)')
        h2 Students
        .header-actions
          span.count-badge #{pagination.total}
          a.btn.btn-sm.btn-outline(href='/admin/students/import')
            i.fas.fa-file-csv
            span Import CSV
      .card-body
        if students && students.length
          table.data-table
            thead
              tr
                th #
                th Name
                th Gender
                th Class
                th Stream
                th Actions
            tbody
              each student, i in (students || [])
                tr
                  td #{((pagination.page-1)*15)+i+1}
                  td #{student.fullName}
                  td #{student.gender}
                  td #{student.class ? student.class.name : '-'}
                  td #{student.stream ? student.stream.name : '-'}
                  td
                    form(method='POST', action=`/admin/students/${student.id}/delete`, style='display:inline')
                      button.btn.btn-danger.btn-sm(type='submit', onclick='return confirm("Remove this student?")')
                        i.fas.fa-user-minus
        else
          .empty-state
            i.fas.fa-user-graduate
            p No students found.

        if pagination.pages > 1
          - const query = {deptId: selectedDeptId, classId: selectedClassId}
          include ../partials/pagination

  script.
    const deptClassMap   = !{JSON.stringify(deptClassMap || {})};
    const classStreamMap = !{JSON.stringify(classStreamMap || {})};

    // ── Add form cascade ─────────────────────────────────────────────────────
    const formDeptSel   = document.getElementById('formDeptSel');
    const formClassSel  = document.getElementById('formClassSel');
    const formStreamSel = document.getElementById('formStreamSel');

    function updateClasses() {
      const did = formDeptSel.value;
      const classes = deptClassMap[did] || [];
      formClassSel.innerHTML = '<option value="">— select class —</option>';
      classes.forEach(function(c) {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = c.name;
        formClassSel.appendChild(opt);
      });
      updateStreams();
    }

    function updateStreams() {
      const cid = formClassSel.value;
      const streams = classStreamMap[cid] || [];
      formStreamSel.innerHTML = '<option value="">— no stream —</option>';
      streams.forEach(function(s) {
        const opt = document.createElement('option');
        opt.value = s.id;
        opt.textContent = s.name;
        formStreamSel.appendChild(opt);
      });
    }

    formDeptSel.addEventListener('change', updateClasses);
    formClassSel.addEventListener('change', updateStreams);

    // ── Filter cascade ───────────────────────────────────────────────────────
    const filterDeptSel  = document.getElementById('filterDeptSel');
    const filterClassSel = document.getElementById('filterClassSel');
    const savedDept  = '!{selectedDeptId}';
    const savedClass = '!{selectedClassId}';

    function updateFilterClasses() {
      const did = filterDeptSel.value;
      const classes = deptClassMap[did] || [];
      filterClassSel.innerHTML = '<option value="">All Classes</option>';
      classes.forEach(function(c) {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = c.name;
        if (String(c.id) === savedClass) opt.selected = true;
        filterClassSel.appendChild(opt);
      });
    }

    filterDeptSel.addEventListener('change', updateFilterClasses);
    if (filterDeptSel.value) updateFilterClasses();
