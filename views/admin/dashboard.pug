extends ../partials/admin-layout

block body
  if !currentYear
    .alert.alert-warning
      i.fas.fa-exclamation-triangle
      span No current academic year set.
      a(href='/admin/academic-years') Set up Academic Year →

  .stats-grid
    .stat-card
      .stat-icon.students
        i.fas.fa-user-graduate
      .stat-info
        h3 #{totalStudents}
        p Total Students
    .stat-card
      .stat-icon.teachers
        i.fas.fa-chalkboard-teacher
      .stat-info
        h3 #{totalTeachers}
        p Total Teachers
    .stat-card
      .stat-icon.classes
        i.fas.fa-door-open
      .stat-info
        h3 #{totalClasses}
        p Total Classes
    .stat-card
      .stat-icon.depts
        i.fas.fa-building
      .stat-info
        h3 #{totalDepts}
        p Departments

  // Full-width Chart Row Container
  .card.mb-4
    .card-header
      h2 Students per Class
      i.fas.fa-chart-bar
    .card-body
      if attendanceData && attendanceData.length && attendanceData.some(d => d.total > 0)
        #chartWrapper(style='width: 100%; height: 320px; position: relative;')
          canvas#enrollmentBarChart(style='display: block; width: 100%; height: 100%;')
      else
        .empty-state
          i.fas.fa-chart-bar
          p No class enrollment data yet.

  if currentYear
    .card.mb-4
      .card-header
        h2 Current Academic Year — #{currentYear.name}
        i.fas.fa-calendar-check
      .card-body
        .year-info-grid
          .year-info-item
            label Start
            strong #{currentYear.startDate}
          .year-info-item
            label End
            strong #{currentYear.endDate}
          if currentYear.terms && currentYear.terms.length
            each term in currentYear.terms
              .year-info-item
                label #{term.name}
                strong #{term.startDate} → #{term.endDate}
                span(class=`status-dot ${term.isOpen ? 'active' : 'inactive'}`) #{term.isOpen ? 'Open' : 'Closed'}

  .quick-actions
    h2 Quick Actions
    .action-grid
      a.action-card(href='/admin/academic-years')
        i.fas.fa-calendar-alt
        span Academic Years
      a.action-card(href='/admin/departments')
        i.fas.fa-building
        span Add Department
      a.action-card(href='/admin/teachers')
        i.fas.fa-user-plus
        span Add Teacher
      a.action-card(href='/admin/classes')
        i.fas.fa-plus-circle
        span Add Class
      a.action-card(href='/admin/students')
        i.fas.fa-user-graduate
        span Add Student
      a.action-card(href='/admin/reports/exam-analysis')
        i.fas.fa-chart-bar
        span Exam Analysis
      a.action-card(href='/admin/holidays')
        i.fas.fa-umbrella-beach
        span Manage Holidays

  script.
    document.addEventListener('DOMContentLoaded', function() {
      var rawData = !{JSON.stringify(attendanceData || [])};
      var canvas = document.getElementById('enrollmentBarChart');
      var wrapper = document.getElementById('chartWrapper');
      if (!canvas || !wrapper) return;

      var items = rawData.filter(function(d) { return d.total > 0; });
      if (!items.length) { wrapper.style.display = 'none'; return; }

      // Read parent container width dynamically for genuine full-width scaling
      var WIDTH = wrapper.clientWidth || 800;
      var HEIGHT = 320;
      canvas.width = WIDTH;
      canvas.height = HEIGHT;

      var ctx = canvas.getContext('2d');
      
      // Adjusted padding to allow space for the descriptive Axis Titles
      var padding = { top: 30, right: 30, bottom: 55, left: 55 };
      var chartWidth = WIDTH - padding.left - padding.right;
      var chartHeight = HEIGHT - padding.top - padding.bottom;

      // Find Max Value for appropriate scaling
      var maxVal = items.reduce(function(max, item) { return item.total > max ? item.total : max; }, 0);
      if (maxVal === 0) maxVal = 10; 
      maxVal = Math.ceil(maxVal * 1.1); // Add 10% ceiling buffer

      // Modern accessible chart color palette
      var colors = [
        '#1a56db', '#0d9488', '#7c3aed', '#ea580c', '#db2777',
        '#2563eb', '#16a34a', '#ca8a04', '#4f46e5', '#e11d48'
      ];

      // Draw Grid System and Axes
      ctx.beginPath();
      ctx.strokeStyle = '#cbd5e1';
      ctx.lineWidth = 1;
      ctx.moveTo(padding.left, padding.top);
      ctx.lineTo(padding.left, HEIGHT - padding.bottom);
      ctx.lineTo(WIDTH - padding.right, HEIGHT - padding.bottom);
      ctx.stroke();

      // Horizontal reference bars & Y-axis scale labels
      var gridLines = 4;
      ctx.fillStyle = '#64748b';
      ctx.font = '11px sans-serif';
      ctx.textAlign = 'right';
      ctx.textBaseline = 'middle';
      for (var g = 0; g <= gridLines; g++) {
        var val = Math.round((maxVal / gridLines) * g);
        var yPos = HEIGHT - padding.bottom - ((val / maxVal) * chartHeight);
        
        ctx.fillText(val, padding.left - 8, yPos);
        
        if (g > 0) {
          ctx.beginPath();
          ctx.strokeStyle = '#f1f5f9';
          ctx.moveTo(padding.left, yPos);
          ctx.lineTo(WIDTH - padding.right, yPos);
          ctx.stroke();
        }
      }

      // ── TYPE AXIS TITLES ──────────────────────────────────────────────────
      // Y-Axis Title: "Students" (Rotated 90 degrees counter-clockwise)
      ctx.save();
      ctx.translate(15, padding.top + chartHeight / 2);
      ctx.rotate(-Math.PI / 2);
      ctx.fillStyle = '#1e293b';
      ctx.font = 'bold 12px sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'bottom';
      ctx.fillText('Students', 0, 0);
      ctx.restore();

      // X-Axis Title: "Classes"
      ctx.fillStyle = '#1e293b';
      ctx.font = 'bold 12px sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top';
      ctx.fillText('Classes', padding.left + chartWidth / 2, HEIGHT - 18);
      // ──────────────────────────────────────────────────────────────────────

      // Calculate dynamic bar dimensions to occupy the full width smoothly
      var totalGaps = items.length + 1;
      var barSpacing = Math.max(12, Math.min(30, chartWidth / totalGaps * 0.25)); 
      var barWidth = (chartWidth - (barSpacing * totalGaps)) / items.length;

      items.forEach(function(item, i) {
        var barHeight = (item.total / maxVal) * chartHeight;
        var xPos = padding.left + barSpacing + i * (barWidth + barSpacing);
        var yPos = HEIGHT - padding.bottom - barHeight;

        var barColor = colors[i % colors.length];

        // Render Unique Colored Bar
        ctx.fillStyle = barColor;
        ctx.fillRect(xPos, yPos, barWidth, barHeight);

        // Render quantitative data labels above bars
        ctx.fillStyle = '#1e293b';
        ctx.font = 'bold 11px sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'bottom';
        ctx.fillText(item.total, xPos + barWidth / 2, yPos - 4);

        // X-axis class labels text string with truncation fallbacks
        ctx.fillStyle = '#64748b';
        ctx.font = '11px sans-serif';
        ctx.textBaseline = 'top';
        var label = item.name;
        var maxLabelWidth = barWidth + (barSpacing * 0.8);
        if (ctx.measureText(label).width > maxLabelWidth) {
          var charLimit = Math.max(3, Math.floor(maxLabelWidth / 7));
          label = label.substring(0, charLimit) + '...';
        }
        ctx.fillText(label, xPos + barWidth / 2, HEIGHT - padding.bottom + 6);
      });
    });