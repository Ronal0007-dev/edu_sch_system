extends ../partials/admin-layout

block body
  if !currentYear
    .alert.alert-warning
      i.fas.fa-exclamation-triangle
      span No current academic year set. 
      a(href='/admin/academic-years') Set up Academic Year →

  .stats-grid
    .stat-card
      .stat-icon.students
        i.fas.fa-user-graduate
      .stat-info
        h3 #{totalStudents}
        p Total Students
    .stat-card
      .stat-icon.teachers
        i.fas.fa-chalkboard-teacher
      .stat-info
        h3 #{totalTeachers}
        p Total Teachers
    .stat-card
      .stat-icon.classes
        i.fas.fa-door-open
      .stat-info
        h3 #{totalClasses}
        p Total Classes
    .stat-card
      .stat-icon.depts
        i.fas.fa-building
      .stat-info
        h3 #{totalDepts}
        p Departments

  .dashboard-grid
    .card
      .card-header
        h2 Students per Class
        i.fas.fa-chart-pie
      .card-body
        if attendanceData && attendanceData.length && attendanceData.some(d => d.total > 0)
          .chart-container
            canvas#enrollmentPieChart(style='width:300px;height:300px;display:block;margin:0 auto')
          .chart-legend#pieLegend
        else
          .empty-state
            i.fas.fa-chart-pie
            p No class enrollment data yet.

    .card
      .card-header
        h2 Class Enrollment Summary
        i.fas.fa-list
      .card-body
        if classes && classes.length
          table.data-table
            thead
              tr
                th Class
                th Department
                th Students
                th Actions
            tbody
              each cls in classes
                tr
                  td
                    span.badge.badge-class #{cls.name}
                  td #{cls.department ? cls.department.code : '-'}
                  td
                    span.count-badge #{cls.students ? cls.students.length : 0}
                  td
                    a.btn.btn-sm(href=`/admin/reports/attendance?classId=${cls.id}`) Attendance
                    a.btn.btn-sm.btn-outline(href=`/admin/reports/exam-analysis?classId=${cls.id}`) Exam Analysis
        else
          .empty-state
            i.fas.fa-inbox
            p No classes yet.
            a.btn.btn-primary(href='/admin/classes') Add Classes

  if currentYear
    .card.mb-4
      .card-header
        h2 Current Academic Year — #{currentYear.name}
        i.fas.fa-calendar-check
      .card-body
        .year-info-grid
          .year-info-item
            label Start
            strong #{currentYear.startDate}
          .year-info-item
            label End
            strong #{currentYear.endDate}
          if currentYear.terms && currentYear.terms.length
            each term in currentYear.terms
              .year-info-item
                label #{term.name}
                strong #{term.startDate} → #{term.endDate}
                span(class=`status-dot ${term.isOpen ? 'active' : 'inactive'}`) #{term.isOpen ? 'Open' : 'Closed'}

  .quick-actions
    h2 Quick Actions
    .action-grid
      a.action-card(href='/admin/academic-years')
        i.fas.fa-calendar-alt
        span Academic Years
      a.action-card(href='/admin/departments')
        i.fas.fa-building
        span Add Department
      a.action-card(href='/admin/teachers')
        i.fas.fa-user-plus
        span Add Teacher
      a.action-card(href='/admin/classes')
        i.fas.fa-plus-circle
        span Add Class
      a.action-card(href='/admin/students')
        i.fas.fa-user-graduate
        span Add Student
      a.action-card(href='/admin/reports/exam-analysis')
        i.fas.fa-chart-bar
        span Exam Analysis
      a.action-card(href='/admin/holidays')
        i.fas.fa-umbrella-beach
        span Manage Holidays

  script.
    document.addEventListener('DOMContentLoaded', function() {
      var rawData = !{JSON.stringify(attendanceData || [])};
      var canvas = document.getElementById('enrollmentPieChart');
      if (!canvas) return;

      // Set actual pixel dimensions
      var SIZE = 300;
      canvas.width = SIZE;
      canvas.height = SIZE;

      var items = rawData.filter(function(d) { return d.total > 0; });
      if (!items.length) { canvas.style.display = 'none'; return; }

      var totalAll = items.reduce(function(s, d) { return s + d.total; }, 0);
      if (totalAll === 0) { canvas.style.display = 'none'; return; }

      var ctx = canvas.getContext('2d');
      var cx = SIZE / 2, cy = SIZE / 2;
      var outerR = SIZE / 2 - 16;
      var innerR = outerR * 0.50;
      var palette = ['#1a56db','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#ec4899','#84cc16','#f97316','#14b8a6'];

      var startAngle = -Math.PI / 2;
      items.forEach(function(item, i) {
        var slice = (item.total / totalAll) * Math.PI * 2;
        // Outer arc
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.arc(cx, cy, outerR, startAngle, startAngle + slice);
        ctx.closePath();
        ctx.fillStyle = palette[i % palette.length];
        ctx.fill();
        ctx.strokeStyle = '#ffffff';
        ctx.lineWidth = 2;
        ctx.stroke();
        // Label on slices large enough
        if (slice > 0.3) {
          var mid = startAngle + slice / 2;
          var lx = cx + (outerR * 0.70) * Math.cos(mid);
          var ly = cy + (outerR * 0.70) * Math.sin(mid);
          ctx.fillStyle = '#ffffff';
          ctx.font = 'bold 12px sans-serif';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillText(item.total, lx, ly);
        }
        startAngle += slice;
      });

      // Punch out donut hole
      ctx.beginPath();
      ctx.arc(cx, cy, innerR, 0, Math.PI * 2);
      ctx.fillStyle = '#ffffff';
      ctx.fill();

      // Centre text
      ctx.fillStyle = '#1e293b';
      ctx.font = 'bold 14px sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText('Students', cx, cy - 9);
      ctx.font = '12px sans-serif';
      ctx.fillStyle = '#64748b';
      ctx.fillText(totalAll + ' total', cx, cy + 11);

      // Build legend
      var legend = document.getElementById('pieLegend');
      if (legend) {
        items.forEach(function(item, i) {
          var el = document.createElement('div');
          el.className = 'legend-item-chart';
          el.innerHTML = '<span class="legend-dot" style="background:' + palette[i % palette.length] + '"></span>'
            + '<span class="legend-label">' + item.name + '</span>'
            + '<span class="legend-pct">' + item.total + ' (' + Math.round((item.total / totalAll) * 100) + '%)</span>';
          legend.appendChild(el);
        });
      }
    });
