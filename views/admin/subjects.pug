extends ../partials/admin-layout

block body
  .two-col-layout
    .card.form-card
      .card-header
        h2 Add Subject
        i.fas.fa-plus
      .card-body
        form(method='POST', action='/admin/subjects')
          .form-group
            label
              span.step-badge 1
              | Department
            select(id='formDeptSel', required)
              option(value='') Select department
              each dept in (departments || [])
                option(value=dept.id) #{dept.name} (#{dept.code})
          .form-group
            label
              span.step-badge 2
              | Class
            select(name='classId', id='formClassSel', required)
              option(value='') — select department first —
          .form-group
            label Subject Name
            input(type='text', name='name', required, placeholder='e.g. Mathematics')
          button.btn.btn-primary(type='submit')
            i.fas.fa-save
            span Save Subject

    .card
      .card-header
        h2 Filter Subjects
        i.fas.fa-filter
      .card-body
        form.filter-form(method='GET', action='/admin/subjects')
          .form-row
            .form-group
              label Department
              select(name='deptId', id='filterDeptSel')
                option(value='') All Departments
                each dept in (departments || [])
                  option(value=dept.id, selected=selectedDeptId==dept.id.toString()) #{dept.name} (#{dept.code})
            .form-group
              label Class
              select(name='classId', id='filterClassSel')
                option(value='') All Classes
                if selectedDeptId && classes.length
                  each cls in classes
                    option(value=cls.id, selected=selectedClassId==cls.id.toString()) #{cls.name}
            button.btn.btn-primary(type='submit')
              i.fas.fa-search
              span Filter

      .card-header(style='border-top:1px solid var(--border)')
        h2 Subjects Grouped by Class
        span.count-badge #{pagination.total}
      .card-body
        if groupedSubjects && groupedSubjects.length
          table.data-table
            thead
              tr
                th(style='width: 20%;') Class
                th(style='width: 15%;') Department
                th(style='width: 65%;') Assigned Subjects
            tbody
              each group in groupedSubjects
                tr
                  td(style='font-weight: bold; color: var(--text-dark);') #{group.className}
                  td
                    if group.deptCode
                      span(class=`dept-badge badge-${group.deptCode.toLowerCase()}`) #{group.deptCode}
                    else
                      | -
                  td
                    div(style='display: flex; flex-wrap: wrap; gap: 8px; align-items: center;')
                      each subject in group.subjects
                        .subject-inline-tag(id='subj-row-'+subject.id, style='display: inline-flex; align-items: center; background: var(--background-alt, #f1f3f5); padding: 4px 10px; border-radius: 4px; border: 1px solid var(--border); font-size: 0.9rem;')
                          span.display-val
                            span.badge.badge-subject(style='margin-right: 6px;') #{subject.name}
                          input.edit-input(type='text', value=subject.name, name='name', style='display:none; max-width: 120px; padding: 2px 5px; font-size: 0.85rem; height: auto; margin-right: 4px;')
                          
                          .action-group(style='display: inline-flex; gap: 4px; margin-left: 6px; align-items: center;')
                            button.btn.btn-sm.edit-btn(type='button', data-id=subject.id, style='padding: 2px 4px; background: transparent; border: none; color: var(--primary); font-size: 0.8rem; cursor: pointer;')
                              i.fas.fa-edit
                            form.save-form(method='POST', action=`/admin/subjects/${subject.id}/edit`, style='display:none; align-items: center; margin: 0;', data-id=subject.id)
                              button.btn.btn-sm.btn-primary(type='submit', style='padding: 2px 4px; font-size: 0.8rem;')
                                i.fas.fa-check
                              button.btn.btn-sm.btn-outline.cancel-btn(type='button', data-id=subject.id, style='padding: 2px 4px; font-size: 0.8rem;')
                                i.fas.fa-times
                            form(method='POST', action=`/admin/subjects/${subject.id}/delete`, style='display:inline; margin: 0;')
                              button.btn.btn-sm(type='submit', onclick='return confirm("Delete?")', style='padding: 2px 4px; background: transparent; border: none; color: var(--danger, #dc3545); font-size: 0.8rem; cursor: pointer;')
                                i.fas.fa-trash
        else
          .empty-state
            i.fas.fa-book
            p No subjects found.

        if pagination.pages > 1
          - const query = {deptId: selectedDeptId, classId: selectedClassId}
          include ../partials/pagination

  script.
    const deptClassMap = !{JSON.stringify(deptClassMap || {})};

    // Add form cascade
    const formDeptSel = document.getElementById('formDeptSel');
    const formClassSel = document.getElementById('formClassSel');
    function updateFormClasses() {
      const classes = deptClassMap[formDeptSel.value] || [];
      formClassSel.innerHTML = '<option value="">— select class —</option>';
      classes.forEach(function(c) {
        const opt = document.createElement('option');
        opt.value = c.id; opt.textContent = c.name;
        formClassSel.appendChild(opt);
      });
    }
    formDeptSel.addEventListener('change', updateFormClasses);

    // Filter cascade
    const filterDeptSel = document.getElementById('filterDeptSel');
    const filterClassSel = document.getElementById('filterClassSel');
    const savedClass = '!{selectedClassId}';
    function updateFilterClasses() {
      const classes = deptClassMap[filterDeptSel.value] || [];
      filterClassSel.innerHTML = '<option value="">All Classes</option>';
      classes.forEach(function(c) {
        const opt = document.createElement('option');
        opt.value = c.id; opt.textContent = c.name;
        if (String(c.id) === savedClass) opt.selected = true;
        filterClassSel.appendChild(opt);
      });
    }
    filterDeptSel.addEventListener('change', updateFilterClasses);
    if (filterDeptSel.value) updateFilterClasses();

    // Inline edit
    document.querySelectorAll('.edit-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        const id = this.dataset.id;
        const row = document.getElementById('subj-row-' + id);
        row.querySelectorAll('.display-val').forEach(function(el) { el.style.display = 'none'; });
        row.querySelectorAll('.edit-input').forEach(function(el) { el.style.display = 'inline-block'; });
        this.style.display = 'none';
        const saveForm = row.querySelector('.save-form');
        saveForm.style.display = 'inline-flex';
        row.querySelectorAll('.edit-input').forEach(function(inp) { saveForm.insertBefore(inp, saveForm.firstChild); });
      });
    });
    document.querySelectorAll('.cancel-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        const id = this.dataset.id;
        const row = document.getElementById('subj-row-' + id);
        row.querySelectorAll('.display-val').forEach(function(el) { el.style.display = ''; });
        row.querySelectorAll('.edit-input').forEach(function(el) { el.style.display = 'none'; });
        row.querySelector('.edit-btn').style.display = '';
        row.querySelector('.save-form').style.display = 'none';
      });
    });
