extends ../layout

block content
  .print-page
    .no-print.print-controls
      button.btn.btn-primary(onclick='window.print()')
        i.fas.fa-print
        span Print All Report Cards
      a.btn.btn-outline(href='javascript:history.back()') ← Back
      span.print-hint #{studentReports.length} report cards

    each sr, idx in studentReports
      .report-card(class=idx < studentReports.length - 1 ? 'page-break-after' : '')
        .report-card-header
          .school-info
            .school-logo-img
              img(src='/images/logo.png', alt='School Logo' width='64')
            div
              h1 Canon Andrea Mwaka School
              p "Never tire of doing what is right" 2 thessalonians 3:13
          .report-meta
            h2 STUDENT REPORT CARD
            p #{term} — #{year}

        .student-details-section
          .detail-row
            .detail-item
              label Student Name:
              strong #{sr.student.fullName}
            .detail-item
              label Class:
              strong #{sr.student.class ? sr.student.class.name : '-'}
            .detail-item
              label Stream:
              strong #{sr.student.stream ? sr.student.stream.name : 'N/A'}
            .detail-item
              label Gender:
              strong #{sr.student.gender}
            .detail-item
              label Attendance:
              - const attPct = sr.totalDays > 0 ? Math.round((sr.presentDays / sr.totalDays) * 100) : 0
              strong #{sr.presentDays}/#{sr.totalDays} days (#{attPct}%)

        .marks-section
          table.report-table
            thead
              tr
                th Subject
                th H/W
                th G/W
                th QZ
                th C/W
                th U/T
                th F/E
                th Total
                th Grade
                th Remarks
            tbody
              each m in sr.marks
                - const subjectName = m.subject ? m.subject.name : ''
                - const className = sr.student.class ? sr.student.class.name : ''
                - const isYear10Art = (subjectName === 'Art & Design' && className === 'Year 10')
                tr
                  td.subject-cell #{m.subject ? m.subject.name : '-'}
                  td #{m.homework}
                  td #{m.groupWork}
                  td #{m.quiz}
                  td #{m.classWork}
                  td #{m.unitTest}
                  td #{m.finalExam}
                  td
                    strong #{m.totalScore ? m.totalScore.toFixed(1) : '-'}
                  td
                    if isYear10Art
                      - const score = m.totalScore || 0
                      - const passed = score > 34
                      span(class=passed ? 'pf-badge pf-pass' : 'pf-badge pf-fail') #{passed ? 'Pass' : 'Fail'}
                    else
                      span(class=`grade-badge grade-${m.grade}`) #{m.grade || '-'}
                  td
                    if isYear10Art
                      - const score = m.totalScore || 0
                      | #{score > 34 ? 'Pass' : 'Fail'}
                    else
                      | #{getRemark(m.grade)}

          if !sr.marks.length
            p.text-muted(style='padding:.5rem') No marks recorded for this term.

        if sr.reportComment && sr.reportComment.comment
          .class-teacher-comment
            h4
              i.fas.fa-comment-alt
              |  Class Teacher's Comment
            p.comment-text #{sr.reportComment.comment}

        .grading-key
          h4 Grading Key:
          .grade-key-grid
            span.grade-badge.grade-A A — Excellent (90-100)
            span.grade-badge.grade-B B — Very Good (80-89)
            span.grade-badge.grade-C C — Good (70-79)
            span.grade-badge.grade-D D — Satisfactory (60-69)
            span.grade-badge.grade-F F — Fail (0-59)

        .report-card-footer
          .signature-area.with-stamp
            .sig-box
              p ___________________________
              p Class Teacher
            .sig-box
              p ___________________________
              p Head Teacher
            //- .stamp-box
              img(src='/images/school-stamp.png', alt='School Stamp' width='64')
              p Official Stamp
