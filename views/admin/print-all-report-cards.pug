extends ../layout

block content
  .print-page
    .no-print.print-controls
      button.btn.btn-primary(onclick='window.print()')
        i.fas.fa-print
        span Print All Report Cards
      a.btn.btn-outline(href='javascript:history.back()') ← Back
      span.print-hint #{studentReports.length} report cards

    each sr, idx in studentReports
      .report-card(class=idx < studentReports.length - 1 ? 'page-break-after' : '')
        .report-card-header
          .school-info
            .school-logo-img
              img(src='/images/logo.png', alt='School Logo' style='max-width:80px;')
            div
              h2 Canon Andrea Mwaka School
              p "Never tire of doing what is right" - 2 Thessalonians 3:13
          .report-meta
            h2 STUDENT REPORT CARD
            p #{term} — #{year}

        .student-details-section
          .detail-row
            .detail-item
              label Student Name:
              strong #{sr.student.fullName}
            .detail-item
              label Class:
              strong #{sr.student.class ? sr.student.class.name : '-'}
            .detail-item
              label Stream:
              strong #{sr.student.stream ? sr.student.stream.name : 'N/A'}
            .detail-item
              label Gender:
              strong #{sr.student.gender}
            .detail-item
              label Attendance:
              - const attPct = sr.totalDays > 0 ? Math.round((sr.presentDays / sr.totalDays) * 100) : 0
              strong #{sr.presentDays}/#{sr.totalDays} days (#{attPct}%)
            .detail-item
              label Term:
              strong #{term} - #{year}

        .marks-section
          table.report-table
            thead
              tr
                th Subject
                th H/W
                th G/W
                th QZ
                th C/W
                th U/T
                th F/E
                th Score
                th Grade
                th Remarks
            tbody
              each m in sr.marks
                tr
                  td.subject-cell #{m.subject ? m.subject.name : '-'}
                  td #{m.homework}
                  td #{m.groupWork}
                  td #{m.quiz}
                  td #{m.classWork}
                  td #{m.unitTest}
                  td #{m.finalExam}
                  td
                    strong #{m.totalScore ? m.totalScore.toFixed(1) : '-'}
                  td
                    span(class=`grade-badge grade-${m.grade}`) #{m.grade || '-'}
                  td #{getRemark(m.grade)}
            if sr.marks.length
              tfoot
                tr.summary-row
                  td(colspan=7) Average
                  - const avg = sr.marks.reduce((s,m)=>s+(m.totalScore||0),0)/sr.marks.length
                  td
                    strong #{avg.toFixed(1)}
                  - const g = avg>=90?'A':avg>=80?'B':avg>=70?'C':avg>=60?'D':'F'
                  td
                    span(class=`grade-badge grade-${g}`) #{g}
                  td —

          if !sr.marks.length
            p.text-muted(style='padding:.5rem') No marks recorded for this term.

        .grading-key
          h4 Grading Key:
          .grade-key-grid
            span.grade-badge.grade-A A — Excellent (90-100)
            span.grade-badge.grade-B B — Very Good (80-89)
            span.grade-badge.grade-C C — Good (70-79)
            span.grade-badge.grade-D D — Satisfactory (60-69)
            span.grade-badge.grade-F F — Fail (0-59)
        .grading-key
          h4 Abreviations:
          .grade-key-grid
            span.grade-badge.grade-A H/W — Homework
            span.grade-badge.grade-B G/W — Group Work
            span.grade-badge.grade-C QZ — Quiz
            span.grade-badge.grade-D C/W — Class Work
            span.grade-badge.grade-F U/T — Unit Test
            span.grade-badge.grade-F F/E — Final Exam

        .report-card-footer
          .signature-area
            .sig-box
              p ___________________________
              p Class Teacher
            .sig-box
              p ___________________________
              p Parent / Guardian
            .sig-box
              p ___________________________
              p Head Teacher
