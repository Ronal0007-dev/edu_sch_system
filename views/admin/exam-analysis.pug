extends ../partials/admin-layout

block body
  style.
    .print-header-block { display: none; }
    @media print {
      .sidebar, .top-bar, .filter-bar, .analysis-header .toolbar-actions,
      .analysis-top-cards, .alert { display: none !important; }
      .main-content { margin-left: 0 !important; }
      .content-area { padding: 0 !important; }
      .app-shell { display: block !important; }
      .print-header-block { display: block !important; }
      .analysis-header { margin-bottom: .75rem !important; }
      .analysis-header h2 { font-size: 1rem !important; }
      .subjects-analysis-grid {
        display: grid !important;
        grid-template-columns: repeat(3, 1fr) !important;
        gap: .85rem !important;
      }
      .subj-analysis-card {
        border: 1.5px solid #e2e8f0 !important;
        border-radius: 8px !important;
        padding: .85rem !important;
        break-inside: avoid;
        page-break-inside: avoid;
      }
      .subj-bar-label { color: #fff !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .subj-bar-fill  { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .stat-pass { background: #dcfce7 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .stat-fail { background: #fee2e2 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .bar-good  { background: #10b981 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .bar-bad   { background: #ef4444 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    }

  .filter-bar
    form.filter-form(method='GET', action='/admin/reports/exam-analysis' id='filterForm')
      .form-row
        //- 1. Department
        .form-group
          label Department
          select#deptSelect(name='deptId')
            option(value='') Select Department
            //- Dynamically build unique departments from the classes list
            - const uniqueDepts = []
            each cls in classes
              if cls.department && !uniqueDepts.some(d => d.id === cls.department.id)
                - uniqueDepts.push(cls.department)
            each dept in uniqueDepts
              option(value=dept.id, selected=analysisData && analysisData.cls && analysisData.cls.departmentId == dept.id) #{dept.name}

        //- 2. Class
        .form-group
          label Class
          select#classSelect(name='classId', required)
            option(value='') Select Class
            each cls in classes
              option(value=cls.id, data-dept=cls.departmentId, selected=analysisData && analysisData.cls && analysisData.cls.id == cls.id) #{cls.name}

        //- 3. Academic Year
        .form-group
          label Academic Year
          select#yearSelect(name='year')
            if currentYear
              option(value=currentYear.name, data-terms=JSON.stringify(currentYear.terms || []), selected=year===currentYear.name) #{currentYear.name} (Current)
            each yr in academicYears
              if !currentYear || yr.id !== currentYear.id
                option(value=yr.name, data-terms=JSON.stringify(yr.terms || []), selected=year===yr.name) #{yr.name}

        //- 4. Term
        .form-group
          label Term
          select#termSelect(name='term')
            option(value='') Select Term
            //- Initially fallback or populates based on selection
            if currentYear && currentYear.terms
              each t in currentYear.terms
                option(value=t.name, selected=term===t.name) #{t.name}#{!t.isOpen ? ' (Closed)' : ''}

        button.btn.btn-primary(type='submit')
          i.fas.fa-search
          span Load Analysis

  if analysisData && analysisData.subjects

    //- Print header — hidden on screen, shown on print at top of page
    .print-header-block
      .report-card
        .report-card-header
          .school-info
            .school-logo-img
              img(src='/images/logo.png', alt='School Logo' width='50')
            div
              h1 Canon Andrea Mwaka School
              p "Never tire of doing what is right" 2 Thessalonians 3:13
          .report-meta
            .report-type-badge.badge-final Final Exam Analysis
            p(style='margin:.2rem 0 0;color:#475569;font-size:.85rem')
            | Final Exam Analysis &nbsp;|&nbsp; #{analysisData.cls ? analysisData.cls.name : ''} &nbsp;|&nbsp; #{term} #{year}
            p(style='margin:.1rem 0 0;color:#64748b;font-size:.8rem')
            | Department: #{analysisData.deptCode} &nbsp;|&nbsp; Total Students: #{analysisData.totalStudents}
          
    .analysis-header
      h2
        i.fas.fa-chart-bar
        | Final Exam Analysis — #{analysisData.cls ? analysisData.cls.name : ''} | #{term}
      .toolbar-actions
        button.btn.btn-outline(onclick='window.print()', type='button')
          i.fas.fa-print
          span Print Analysis
        a.btn.btn-primary(href=`/admin/reports/academic-report/${analysisData.cls ? analysisData.cls.id : ''}?term=${term}&year=${year}`, target='_blank')
          i.fas.fa-file-alt
          span Academic Report

    .analysis-top-cards
      .analysis-stat-card
        .asi-icon
          i.fas.fa-users
        .asi-info
          h3 #{analysisData.totalStudents}
          p Total Students
      .analysis-stat-card
        .asi-icon.asi-dept
          i.fas.fa-building
        .asi-info
          h3 #{analysisData.deptCode}
          p Department

    if analysisData.subjects.length
      .subjects-analysis-grid
        each subj in analysisData.subjects
          .subj-analysis-card
            .subj-name #{subj.subject ? subj.subject.name : 'Unknown'}
            .subj-stats
              .subj-stat-item.stat-total
                .stat-num #{subj.total}
                .stat-lbl Total Sat
              .subj-stat-item.stat-pass
                .stat-num #{subj.pass}
                .stat-lbl Pass
              .subj-stat-item.stat-fail
                .stat-num #{subj.fail}
                .stat-lbl Fail
            .subj-bar
              - const passPct = subj.total > 0 ? Math.round((subj.pass/subj.total)*100) : 0
              .subj-bar-fill(style=`width:${passPct}%`, class=passPct>=50?'bar-good':'bar-bad')
              span.subj-bar-label #{passPct}% Pass Rate
    else
      .empty-state No final exam marks recorded yet.

  else
    .empty-state
      i.fas.fa-hand-pointer
      p Select a class above to view final exam analysis.
  block append scripts
    script.
      document.addEventListener('DOMContentLoaded', function() {
        const deptSelect = document.getElementById('deptSelect');
        const classSelect = document.getElementById('classSelect');
        const yearSelect = document.getElementById('yearSelect');
        const termSelect = document.getElementById('termSelect');

        // Keep reference to all class options originally rendered
        const allClassOptions = Array.from(classSelect.querySelectorAll('option')).slice(1);
        
        // ── CASCADE 1: Department -> Class ──
        deptSelect.addEventListener('change', function() {
          const selectedDeptId = this.value;
          
          // Clear options except the placeholder
          classSelect.innerHTML = '<option value="">Select Class</option>';
          
          // Filter and re-append valid options
          allClassOptions.forEach(opt => {
            if (!selectedDeptId || opt.getAttribute('data-dept') === selectedDeptId) {
              classSelect.appendChild(opt.cloneNode(true));
            }
          });
          
          // Trigger chain reset down the line
          classSelect.dispatchEvent(new Event('change'));
        });

        // ── CASCADE 2: Academic Year -> Term ──
        yearSelect.addEventListener('change', function() {
          const selectedOption = this.options[this.selectedIndex];
          if (!selectedOption || !selectedOption.getAttribute('data-terms')) return;

          try {
            const terms = JSON.parse(selectedOption.getAttribute('data-terms'));
            const currentTermValue = termSelect.value; // Preserve choice if possible
            
            termSelect.innerHTML = '';
            if(terms.length === 0) {
              // Fallback default terms if year contains no records
              ['Term 1', 'Term 2', 'Term 3'].forEach(t => {
                const opt = new Option(t, t);
                if(t === currentTermValue) opt.selected = true;
                termSelect.add(opt);
              });
            } else {
              terms.forEach(t => {
                const label = t.name + (!t.isOpen ? ' (Closed)' : '');
                const opt = new Option(label, t.name);
                if(t.name === currentTermValue) opt.selected = true;
                termSelect.add(opt);
              });
            }
          } catch (e) {
            console.error("Error parsing terms structure:", e);
          }
        });

        // Initialize dropdown layouts on page loads to respect selections
        if (deptSelect.value) {
          const deptId = deptSelect.value;
          const initialClassVal = classSelect.value;
          classSelect.innerHTML = '<option value="">Select Class</option>';
          allClassOptions.forEach(opt => {
            if (opt.getAttribute('data-dept') === deptId) {
              const clone = opt.cloneNode(true);
              if(clone.value === initialClassVal) clone.selected = true;
              classSelect.appendChild(clone);
            }
          });
        }
        
        if (yearSelect.value) {
          yearSelect.dispatchEvent(new Event('change'));
        }
      });
