extends ../partials/admin-layout

block body
  .two-col-layout
    .card.form-card
      .card-header
        h2 Add Stream
        i.fas.fa-plus
      .card-body
        form(method='POST', action='/admin/streams')
          .form-group
            label Stream Name
            input(type='text', name='name', required, placeholder='e.g. A, B, East, West')
          .form-group
            label Class
            select(name='classId', required)
              option(value='') Select class
              each cls in classes
                option(value=cls.id) #{cls.name} (#{cls.department ? cls.department.code : ''})
          button.btn.btn-primary(type='submit')
            i.fas.fa-save
            span Save Stream

    .card
      .card-header
        h2 Streams by Class
        span.count-badge #{totalStreams}
      .card-body
        if classes.length
          each cls in classes
            .stream-group
              .stream-group-header
                h3 #{cls.name}
                span.stream-count #{cls.streams ? cls.streams.length : 0} stream(s)
              if cls.streams && cls.streams.length
                table.data-table
                  thead
                    tr
                      th Name
                      th Actions
                  tbody
                    each stream in cls.streams
                      tr(id='str-row-'+stream.id)
                        td.editable-cell
                          span.display-val
                            span.badge.badge-stream #{stream.name}
                          input.edit-input(type='text', value=stream.name, name='name', style='display:none')
                        td
                          .action-group
                            button.btn.btn-sm.btn-outline.edit-btn(type='button', data-id=stream.id)
                              i.fas.fa-edit
                              span Edit
                            form.save-form(method='POST', action=`/admin/streams/${stream.id}/edit`, style='display:none', data-id=stream.id)
                              button.btn.btn-sm.btn-primary(type='submit')
                                i.fas.fa-check
                                span Save
                              button.btn.btn-sm.btn-outline.cancel-btn(type='button', data-id=stream.id)
                                i.fas.fa-times
                            form(method='POST', action=`/admin/streams/${stream.id}/delete`, style='display:inline')
                              button.btn.btn-danger.btn-sm(type='submit', onclick='return confirm("Delete this stream?")')
                                i.fas.fa-trash
              else
                .empty-state
                  i.fas.fa-code-branch
                  p No streams configured for this class.
        else
          .empty-state
            i.fas.fa-code-branch
            p No classes or streams configured yet.

  script.
    document.querySelectorAll('.edit-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        const id = this.dataset.id;
        const row = document.getElementById('str-row-' + id);
        row.querySelectorAll('.display-val').forEach(function(el) { el.style.display = 'none'; });
        row.querySelectorAll('.edit-input').forEach(function(el) { el.style.display = 'inline-block'; });
        this.style.display = 'none';
        const saveForm = row.querySelector('.save-form');
        saveForm.style.display = 'inline-flex';
        row.querySelectorAll('.edit-input').forEach(function(inp) { saveForm.insertBefore(inp, saveForm.firstChild); });
      });
    });
    document.querySelectorAll('.cancel-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        const id = this.dataset.id;
        const row = document.getElementById('str-row-' + id);
        row.querySelectorAll('.display-val').forEach(function(el) { el.style.display = ''; });
        row.querySelectorAll('.edit-input').forEach(function(el) { el.style.display = 'none'; });
        row.querySelector('.edit-btn').style.display = '';
        row.querySelector('.save-form').style.display = 'none';
      });
    });
