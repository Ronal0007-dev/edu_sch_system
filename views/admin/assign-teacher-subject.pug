extends ../partials/admin-layout

block body
  .two-col-layout
    .card.form-card
      .card-header
        h2 Assign Teacher to Subjects
        i.fas.fa-link
      .card-body
        form(method='POST', action='/admin/assignments/teacher-subject')
          .form-group
            label Select Teacher
            select(name='teacherId', required)
              option(value='') Choose teacher
              each teacher in (teachers || [])
                option(value=teacher.id) #{teacher.fullName} (#{teacher.department ? teacher.department.code : ''})
          .form-group
            label
              span.step-badge 1
              | Department
            select(name='_formDeptId', id='formDeptSel', required)
              option(value='') Select department
              each dept in (departments || [])
                option(value=dept.id) #{dept.name} (#{dept.code})
          .form-group
            label
              span.step-badge 2
              | Class
            select(name='classId', id='formClassSel', required)
              option(value='') — select department first —
          .form-group
            label
              span.step-badge 3
              | Subjects (Ctrl/Cmd for multiple)
            select(name='subjectIds', id='formSubjectSel', required, multiple, style='height:140px')
              option(value='') — select class first —
          button.btn.btn-primary(type='submit')
            i.fas.fa-link
            span Assign

    .card
      .card-header
        h2 Filter Assignments
        i.fas.fa-filter
      .card-body
        form.filter-form(method='GET', action='/admin/assignments/teacher-subject')
          .form-row
            .form-group
              label Department
              select(name='deptId', id='filterDeptSel')
                option(value='') All Departments
                each dept in (departments || [])
                  option(value=dept.id, selected=selectedDeptId==dept.id.toString()) #{dept.name} (#{dept.code})
            .form-group
              label Class
              select(name='classId', id='filterClassSel')
                option(value='') All Classes
                if selectedDeptId && classes.length
                  each cls in classes
                    option(value=cls.id, selected=selectedClassId==cls.id.toString()) #{cls.name}
            button.btn.btn-primary(type='submit')
              i.fas.fa-search
              span Filter

      .card-header(style='border-top:1px solid var(--border)')
        h2 Current Assignments
        span.count-badge #{pagination.total}
      .card-body
        if assignments.length
          table.data-table
            thead
              tr
                th Teacher
                th Class
                th Department
                th Subject
                th Actions
            tbody
              //- 
              each teacherGroup in (uniqueTeacherAssignments || [])
                tr
                  td
                    .teacher-name
                      i.fas.fa-user-circle
                      strong #{teacherGroup.teacherName}
                  td(colspan="4")
                    .subject-tags-list(style="display: flex; flex-wrap: wrap; gap: 8px;")
                      each sub in teacherGroup.subjects
                        span.badge.badge-subject(style="padding: 6px 12px; margin-right: 4px;")
                          | #{sub.name} (#{sub.className})
                          form(method='POST', action=`/admin/assignments/teacher-subject/${sub.id}/remove`, style='display:inline; margin-left: 8px;')
                            button.btn-link(type='submit', onclick='return confirm("Remove this subject assignment?")', style='background:none; border:none; color:var(--danger); cursor:pointer;')
                              i.fas.fa-times-circle
        else
          .empty-state
            i.fas.fa-link
            p No teacher-subject assignments found.

        if pagination.pages > 1
          - const query = {deptId: selectedDeptId, classId: selectedClassId}
          include ../partials/pagination

  script.
    const deptClassMap = !{JSON.stringify(deptClassMap)};
    const classSubjectMap = !{JSON.stringify(classSubjectMap)};

    // ── Form cascade: Dept → Class → Subjects ──────────────────────────────
    const formDeptSel    = document.getElementById('formDeptSel');
    const formClassSel   = document.getElementById('formClassSel');
    const formSubjectSel = document.getElementById('formSubjectSel');

    function updateFormClasses() {
      const did = formDeptSel.value;
      const classes = deptClassMap[did] || [];
      formClassSel.innerHTML = '<option value="">— select class —</option>';
      classes.forEach(function(c) {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = c.name;
        formClassSel.appendChild(opt);
      });
      updateFormSubjects();
    }

    function updateFormSubjects() {
      const cid = formClassSel.value;
      const subjects = classSubjectMap[cid] || [];
      formSubjectSel.innerHTML = '<option value="">— select class first —</option>';
      subjects.forEach(function(s) {
        const opt = document.createElement('option');
        opt.value = s.id;
        opt.textContent = s.name;
        formSubjectSel.appendChild(opt);
      });
    }

    formDeptSel.addEventListener('change', updateFormClasses);
    formClassSel.addEventListener('change', updateFormSubjects);

    // ── Filter cascade: Dept → Class ───────────────────────────────────────
    const filterDeptSel  = document.getElementById('filterDeptSel');
    const filterClassSel = document.getElementById('filterClassSel');
    const savedDept  = '!{selectedDeptId}';
    const savedClass = '!{selectedClassId}';

    function updateFilterClasses() {
      const did = filterDeptSel.value;
      const classes = deptClassMap[did] || [];
      filterClassSel.innerHTML = '<option value="">All Classes</option>';
      classes.forEach(function(c) {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = c.name;
        if (String(c.id) === savedClass) opt.selected = true;
        filterClassSel.appendChild(opt);
      });
    }

    filterDeptSel.addEventListener('change', updateFilterClasses);
    if (filterDeptSel.value) updateFilterClasses();
