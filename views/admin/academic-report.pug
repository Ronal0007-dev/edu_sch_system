extends ../layout

block content
  .print-page
    .no-print.print-controls
      button.btn.btn-primary(onclick='window.print()')
        i.fas.fa-print
        span Print Academic Report
      a.btn.btn-outline(href='javascript:history.back()') ← Back

    .print-doc
      .print-header
        .print-logo
          img(src='/images/logo.png', alt='School Logo', style='width:64px;height:64px;object-fit:contain')
        div
          h1 Canon Andrea Mwaka School
          h2 Academic Report — Final Examination
          p Class: #{cls ? cls.name : ''} &nbsp;|&nbsp; #{cls && cls.department ? cls.department.code : ''} &nbsp;|&nbsp; #{term} #{year}

      table.print-table
        thead
          tr
            th #
            th Student
            th Stream
            each subj in subjects
              th #{subj.name.slice(0,3)}
            if isPrimary
              th Classification
            else
              th Total %
              th Result
        tbody
          each sr, i in studentReports
            - const student = sr.student
            tr
              td #{i+1}
              td #{student.fullName}
              td #{student.stream ? student.stream.name : '-'}
              each subj in subjects
                - const m = sr.marks.find(mk => mk.subjectId === subj.id)
                - const fe = m ? m.finalExam : null
                - const feMax = m ? m.finalExamMax : null
                if isPrimary
                  td(class=fe!==null?(fe>=21?'cell-pass':'cell-fail'):'')
                    | #{fe !== null ? fe : '-'}
                else
                  td(class=fe!==null&&feMax?(fe/feMax*100>=40?'cell-pass':'cell-fail'):'')
                    | #{fe !== null ? fe : '-'}#{feMax ? '/'+feMax : ''}
              if isPrimary
                - const allFe = sr.marks.map(mk=>mk.finalExam).filter(v=>v!==null&&v!==undefined)
                - const avgFe = allFe.length ? (allFe.reduce((a,b)=>a+b,0)/allFe.length) : null
                - const cls2 = avgFe===null?'-':avgFe===0?'Unclassified':avgFe<=10?'Basic':avgFe<=20?'Aspiring':avgFe<=30?'Good':avgFe<=40?'High':'Outstanding'
                td
                  strong #{cls2}
              else
                - const allPct = sr.marks.filter(mk=>mk.finalExam!==null&&mk.finalExamMax).map(mk=>(mk.finalExam/mk.finalExamMax)*100)
                - const avgPct = allPct.length ? (allPct.reduce((a,b)=>a+b,0)/allPct.length) : null
                td
                  strong #{avgPct ? avgPct.toFixed(1)+'%' : '-'}
                td #{avgPct ? (avgPct>=40?'Pass':'Fail') : '-'}

      if isPrimary
        .exam-key
          h4 Classification Key (out of 50):
          .grade-key-grid
            span.prim-grade.prim-outstanding Outstanding (41–50)
            span.prim-grade.prim-high High (31–40)
            span.prim-grade.prim-good Good (21–30)
            span.prim-grade.prim-aspiring Aspiring (11–20)
            span.prim-grade.prim-basic Basic (1–10)
            span.prim-grade.prim-unclassified Unclassified (0)
      else
        .exam-key
          h4 Pass threshold: ≥ 40% of max mark per subject.

      .print-footer
        .sig-grid
          .sig-box
            p ___________________________
            p Class Teacher
          .sig-box
            p ___________________________
            p Head Teacher
          .sig-box
            p ___________________________
            p Date
