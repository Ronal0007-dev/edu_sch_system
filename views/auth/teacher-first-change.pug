extends ../layout

block content
  .auth-page
    .auth-card
      .auth-header
        .auth-icon.teacher-icon
          i.fas.fa-key
        h1 Set Your Password
        p Welcome! Please set a new password before continuing.
      .alert.alert-info
        i.fas.fa-info-circle
        span This is your first login. You must change your default password to continue.
      if error && error.length
        each msg in error
          .alert.alert-error
            i.fas.fa-exclamation-circle
            span #{msg}
      form.auth-form(method='POST', action='/auth/teacher/first-change-password')
        .form-group
          label New Password
          .input-wrap
            i.fas.fa-key
            input(type='password', name='newPassword', required, placeholder='At least 6 characters', minlength=6)
        .form-group
          label Confirm New Password
          .input-wrap
            i.fas.fa-key
            input(type='password', name='confirmPassword', required, placeholder='Repeat new password')
        .password-rules
          p Password must be at least 6 characters long.
        button.btn.btn-primary.btn-full.btn-teacher(type='submit')
          i.fas.fa-check
          span Set Password & Continue
