extends ../layout

block content
  .report-card-page
    .report-card-controls.no-print
      a.btn.btn-outline(href='javascript:history.back()')
        i.fas.fa-arrow-left
        span Back
      button.btn.btn-primary(onclick='window.print()')
        i.fas.fa-print
        span Print Progressive Report
      .term-selector
        form(method='GET', action=`/teacher/progressive-report/${student.id}`)
          .form-row
            .form-group
              label Term
              select(name='term')
                if allTerms && allTerms.length
                  each t in allTerms
                    option(value=t.name, selected=term===t.name) #{t.name}#{!t.isOpen ? ' (Closed)' : ''}
                else
                  option(value='Term 1', selected=term==='Term 1') Term 1
            .form-group
              label Year
              select(name='year')
                if currentYear
                  option(value=currentYear.name, selected=year===currentYear.name) #{currentYear.name}
                each yr in academicYears
                  if !currentYear || yr.id !== currentYear.id
                    option(value=yr.name, selected=year===yr.name) #{yr.name}
            button.btn.btn-sm.btn-outline(type='submit') Load
      a.btn.btn-outline(href=`/teacher/final-report/${student.id}?term=${term}&year=${year}`)
        i.fas.fa-file-alt
        span View Final Report

    .report-card
      .report-card-header
        .school-info
          .school-logo-img
            img(src='/images/logo.png', alt='School Logo' width='50' height='50')
          div
            h1 Canon Andrea Mwaka School
            p "Never tire of doing what is right" 2 Thessalonians 3:13
        .report-meta
          .report-type-badge.badge-progressive PROGRESSIVE REPORT
          h2 Continuous Assessment
          p #{term} — #{year}

      .student-details-section
        .detail-row
          .detail-item
            label Student Name:
            strong #{student.fullName}
          .detail-item
            label Class:
            strong #{student.class ? student.class.name : '-'}
          .detail-item
            label Stream:
            strong #{student.stream ? student.stream.name : 'N/A'}
          .detail-item
            label Gender:
            strong #{student.gender}
          .detail-item
            label Attendance:
            - const attPct = totalDays > 0 ? Math.round((presentDays / totalDays) * 100) : 0
            strong #{presentDays}/#{totalDays} days (#{attPct}%)

      .marks-section
        table.report-table
          thead
            tr
              th Subject
              th H/W
              th G/W
              th QZ
              th C/W
              th U/T
              th CA Total
              th Grade
              th Remarks
          tbody
            if marks.length
              each m in marks
                tr
                  td.subject-cell #{m.subject ? m.subject.name : '-'}
                  td #{m.homework != null ? m.homework : '-'}
                  td #{m.groupWork != null ? m.groupWork : '-'}
                  td #{m.quiz != null ? m.quiz : '-'}
                  td #{m.classWork != null ? m.classWork : '-'}
                  td #{m.unitTest != null ? m.unitTest : '-'}
                  td
                    strong #{m.totalScore != null ? m.totalScore.toFixed(1) : '-'}
                  td
                    span(class=`grade-badge grade-${m.grade}`) #{m.grade || '-'}
                  td #{getRemark(m.grade)}
            else
              tr
                td(colspan=9, style='text-align:center;padding:1rem;color:#64748b') No marks recorded for #{term}.
          if marks.length
            tfoot
              tr.summary-row
                td(colspan=6) Overall Average
                - const avg = marks.reduce((s,m)=>s+(m.totalScore||0),0)/marks.length
                td
                  strong #{avg.toFixed(1)}
                - const g = avg>=90?'A':avg>=80?'B':avg>=70?'C':avg>=60?'D':'F'
                td
                  span(class=`grade-badge grade-${g}`) #{g}
                td #{getRemark(g)}

      .grading-key
        h4 Grading Key (CA):
        .grade-key-grid
          span.grade-badge.grade-A A — Excellent (90–100)
          span.grade-badge.grade-B B — Very Good (80–89)
          span.grade-badge.grade-C C — Good (70–79)
          span.grade-badge.grade-D D — Satisfactory (60–69)
          span.grade-badge.grade-F F — Fail (0–59)

      .weight-key
        h4 Component Abbreviations:
        .weight-row-display
          span H/W - Home Work
          span G/W - Group Work
          span QZ - Quiz
          span C/W - Class Work
          span U/T - Unit Test

      if reportComment && reportComment.comment
        .class-teacher-comment
          h4
            i.fas.fa-comment-alt
            |  Class Teacher's Comment
          p.comment-text #{reportComment.comment}

      .report-card-footer
        .signature-area
          .sig-box
            p ___________________________
            p Class Teacher
          .sig-box
            p ___________________________
            p Head Teacher

      .print-date Generated: #{new Date().toLocaleDateString()}
