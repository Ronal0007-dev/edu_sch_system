extends ../partials/teacher-layout

block body
  .filter-bar
    form.filter-form(method='GET', action='/teacher/attendance')
      .form-row
        .form-group
          label Select Class
          select(name='classId', required)
            option(value='') Choose your class
            each cls in classes
              option(value=cls.id, selected=selectedClass && selectedClass.id==cls.id) #{cls.name} (#{cls.department ? cls.department.code : ''})
        button.btn.btn-primary(type='submit')
          i.fas.fa-search
          span Load Class

  if !canTakeAttendance
    .alert.alert-warning.big-alert
      i.fas.fa-ban
      div
        h3 Attendance Not Available
        p #{blockReason}
    if selectedClass
      .card.mb-4
        .card-header
          h2 Print / View Attendance for #{selectedClass.name}
          i.fas.fa-print
        .card-body
          form.filter-form(method='GET', action='/teacher/attendance/print')
            .form-row
              input(type='hidden', name='classId', value=selectedClass.id)
              .form-group
                label Select Date to Print
                input(type='date', name='date', value=today)
              a.btn.btn-primary(href=`/teacher/attendance/print?classId=${selectedClass.id}&date=${today}`, target='_blank')
                i.fas.fa-print
                span Print Today's Attendance

  else if selectedClass && students.length
    .attendance-header
      .attendance-meta
        h2
          i.fas.fa-calendar-check
          | Attendance — #{selectedClass.name}
        .date-display
          i.fas.fa-calendar-alt
          span #{today}
          span.date-note (Auto-set — cannot be changed)
      .attendance-actions
        a.btn.btn-outline.btn-sm(href=`/teacher/attendance/print?classId=${selectedClass.id}&date=${today}`, target='_blank')
          i.fas.fa-print
          span Print
      .attendance-legend
        span.legend-item
          span.dot.present
          | Present
        span.legend-item
          span.dot.absent
          | Absent
        span.legend-item
          span.dot.sick
          | Sick

    form(method='POST', action='/teacher/attendance/submit')
      input(type='hidden', name='classId', value=selectedClass.id)

      .quick-mark.no-print
        span Mark all:
        button.btn.btn-sm(type='button', onclick='markAll("present")') ✓ All Present
        button.btn.btn-sm.btn-outline(type='button', onclick='markAll("absent")') ✗ All Absent

      .students-attendance-list
        each student in students
          .student-row(class=student.existingStatus ? 'has-record' : '')
            .student-info
              .student-avatar #{student.fullName.charAt(0)}
              .student-details
                strong #{student.fullName}
                if student.stream
                  span.stream-tag #{student.stream.name}
            .status-buttons
              label.status-btn.present-btn
                input(type='radio', name=`status_${student.id}`, value='present', checked=student.existingStatus==='present')
                i.fas.fa-check
                span Present
              label.status-btn.absent-btn
                input(type='radio', name=`status_${student.id}`, value='absent', checked=student.existingStatus==='absent')
                i.fas.fa-times
                span Absent
              label.status-btn.sick-btn
                input(type='radio', name=`status_${student.id}`, value='sick', checked=student.existingStatus==='sick')
                i.fas.fa-thermometer-half
                span Sick
            if student.existingStatus
              .existing-tag
                i.fas.fa-check-circle
                span Saved: #{student.existingStatus}

      .form-actions.sticky-actions
        button.btn.btn-primary.btn-lg(type='submit')
          i.fas.fa-save
          span Save All Attendance
        a.btn.btn-outline(href=`/teacher/attendance/print?classId=${selectedClass.id}&date=${today}`, target='_blank')
          i.fas.fa-print
          span Print

  else if selectedClass && students.length === 0
    .empty-state
      i.fas.fa-user-slash
      p No students in this class.
  else
    .empty-state
      i.fas.fa-hand-pointer
      p Select a class above to take attendance.

  script.
    function markAll(status) {
      document.querySelectorAll(`input[type="radio"][value="${status}"]`).forEach(r => r.checked = true);
    }
