extends ../partials/teacher-layout

block body
  .filter-bar
    .form-row
      .form-group
        label Term
        select#termSel
          if currentYear && currentYear.terms && currentYear.terms.length
            each t in currentYear.terms
              option(value=t.name) #{t.name}#{!t.isOpen ? ' (Closed)' : ''}
          else
            option(value='Term 1') Term 1
            option(value='Term 2') Term 2
            option(value='Term 3') Term 3
      .form-group
        label Class
        select#classSel
          option(value='') All Classes
          each cls in classes
            option(value=cls.id) #{cls.name}
      .form-group
        label Stream
        select#streamSel
          option(value='') All Streams
      .form-group
        label Year
        select#yearSel
          if currentYear
            option(value=currentYear.name) #{currentYear.name} (Current)
          each yr in academicYears
            if !currentYear || yr.id !== currentYear.id
              option(value=yr.name) #{yr.name}

  each cls in classes
    .card.mb-4(data-class-id=cls.id)
      .card-header
        h2 #{cls.name}
        .toolbar-actions
          if cls.isClassTeacher
            span.role-badge.role-class_teacher Class Teacher
      .card-body
        if cls.students && cls.students.length
          table.data-table
            thead
              tr
                th #
                th Student
                th Stream
                th Progressive Report
                th Final Report
            tbody
              each student, i in cls.students
                tr(data-stream-id=student.stream ? student.stream.id : '')
                  td #{i+1}
                  td
                    .student-mini
                      .mini-avatar #{student.fullName.charAt(0)}
                      div
                        strong #{student.fullName}
                        small #{student.gender}
                  td #{student.stream ? student.stream.name : '-'}
                  td
                    a.btn.btn-sm.btn-primary.prog-link(href=`/teacher/progressive-report/${student.id}`, data-student=student.id)
                      i.fas.fa-chart-line
                      span CA Report
                  td
                    a.btn.btn-sm.btn-outline.final-link(href=`/teacher/final-report/${student.id}`, data-student=student.id)
                      i.fas.fa-file-alt
                      span Final Report
        else
          p.text-muted No students in #{cls.name}

  script.
    const termSel = document.getElementById('termSel');
    const yearSel = document.getElementById('yearSel');
    const classSel = document.getElementById('classSel');
    const streamSel = document.getElementById('streamSel');
    const classStreamMap = !{JSON.stringify(classStreamMap || {})};

    function updateStreams() {
      const cid = classSel.value;
      const streams = classStreamMap[cid] || [];
      streamSel.innerHTML = '<option value="">All Streams</option>';
      streams.forEach(function(stream) {
        const opt = document.createElement('option');
        opt.value = stream.id;
        opt.textContent = stream.name;
        streamSel.appendChild(opt);
      });
    }

    function updateCards() {
      const selectedClass = classSel.value;
      const selectedStream = streamSel.value;
      document.querySelectorAll('.card.mb-4[data-class-id]').forEach(card => {
        const cardId = card.getAttribute('data-class-id');
        const matchesClass = !selectedClass || String(cardId) === String(selectedClass);
        const streams = classStreamMap[cardId] || [];
        const matchesStream = !selectedStream || streams.some(s => String(s.id) === String(selectedStream));
        card.style.display = matchesClass && matchesStream ? '' : 'none';
        if (matchesClass && matchesStream) {
          card.querySelectorAll('tbody tr').forEach(row => {
            const rowStream = row.getAttribute('data-stream-id') || '';
            const rowVisible = !selectedStream || String(rowStream) === String(selectedStream);
            row.style.display = rowVisible ? '' : 'none';
          });
        }
      });
    }

    function updateLinks() {
      const term = encodeURIComponent(termSel.value);
      const year = encodeURIComponent(yearSel.value);
      document.querySelectorAll('.prog-link').forEach(a => {
        a.href = '/teacher/progressive-report/' + a.dataset.student + '?term=' + term + '&year=' + year;
      });
      document.querySelectorAll('.final-link').forEach(a => {
        a.href = '/teacher/final-report/' + a.dataset.student + '?term=' + term + '&year=' + year;
      });
    }
    termSel.addEventListener('change', updateLinks);
    yearSel.addEventListener('change', updateLinks);
    classSel.addEventListener('change', function() { updateStreams(); updateCards(); });
    streamSel.addEventListener('change', updateCards);
    updateStreams();
    updateCards();
    updateLinks();
