extends ../layout

block content
  .report-card-page
    .report-card-controls.no-print
      a.btn.btn-outline(href='javascript:history.back()')
        i.fas.fa-arrow-left
        span Back
      button.btn.btn-primary(onclick='window.print()')
        i.fas.fa-print
        span Print Final Report
      .term-selector
        form(method='GET', action=`/teacher/final-report/${student.id}`)
          .form-row
            .form-group
              label Term
              select(name='term')
                if allTerms && allTerms.length
                  each t in allTerms
                    option(value=t.name, selected=term===t.name) #{t.name}#{!t.isOpen ? ' (Closed)' : ''}
                else
                  option(value='Term 1', selected=term==='Term 1') Term 1
            .form-group
              label Year
              select(name='year')
                if currentYear
                  option(value=currentYear.name, selected=year===currentYear.name) #{currentYear.name}
                each yr in academicYears
                  if !currentYear || yr.id !== currentYear.id
                    option(value=yr.name, selected=year===yr.name) #{yr.name}
            button.btn.btn-sm.btn-outline(type='submit') Load
      a.btn.btn-outline(href=`/teacher/progressive-report/${student.id}?term=${term}&year=${year}`)
        i.fas.fa-file-alt
        span View Progressive Report

    .report-card
      .report-card-header
        .school-info
          .school-logo-img
            img(src='/images/logo.png', alt='School Logo' width='50' height='50')
          div
            h1 Canon Andrea Mwaka School
            p "Never tire of doing what is right" 2 Thessalonians 3:13
        .report-meta
          .report-type-badge.badge-final FINAL REPORT
          h2 Final Examination Results
          p #{term} — #{year}

      .student-details-section
        .detail-row
          .detail-item
            label Student Name:
            strong #{student.fullName}
          .detail-item
            label Class:
            strong #{student.class ? student.class.name : '-'}
          .detail-item
            label Stream:
            strong #{student.stream ? student.stream.name : 'N/A'}
          .detail-item
            label Gender:
            strong #{student.gender}
          .detail-item
            label Department:
            strong #{deptCode}

      .marks-section
        if isPrimary
          //- PRIMARY: out of 50 with classification
          table.report-table
            thead
              tr
                th Subject
                th Score (out of 50)
                th Classification
                th Result
            tbody
              if marks.length
                each m in marks
                  - const fe = m.finalExam != null ? m.finalExam : null
                  - const pg = fe===null?null:fe===0?{grade:'U',label:'Unclassified'}:fe<=10?{grade:'B',label:'Basic'}:fe<=20?{grade:'As',label:'Aspiring'}:fe<=30?{grade:'G',label:'Good'}:fe<=40?{grade:'H',label:'High'}:{grade:'O',label:'Outstanding'}
                  - const passed = fe !== null && fe >= 21
                  tr
                    td.subject-cell #{m.subject ? m.subject.name : '-'}
                    td
                      strong #{fe !== null ? fe : '—'}
                    td
                      if pg
                        span(class=`prim-grade prim-${pg.label.toLowerCase()}`) #{pg.label}
                      else
                        | —
                    td
                      if fe !== null
                        span(class=`pf-badge ${passed?'pf-pass':'pf-fail'}`) #{passed ? 'Pass' : 'Fail'}
                      else
                        | —
              else
                tr
                  td(colspan=4, style='text-align:center;padding:1rem;color:#64748b') No final exam marks recorded.
          .exam-key
            h4 Classification (out of 50):
            .grade-key-grid
              span.prim-grade.prim-outstanding Outstanding (41–50)
              span.prim-grade.prim-high High (31–40)
              span.prim-grade.prim-good Good (21–30)
              span.prim-grade.prim-aspiring Aspiring (11–20)
              span.prim-grade.prim-basic Basic (1–10)
              span.prim-grade.prim-unclassified Unclassified (0)
          .exam-key(style='margin-top:.5rem')
            h4 Pass Threshold: ≥ 21 out of 50

        else
          //- SECONDARY: teacher-set max, pass >= 40%
          table.report-table
            thead
              tr
                th Subject
                th Score
                th Max Mark
                th Percentage
                th Result
            tbody
              if marks.length
                each m in marks
                  - const fe = m.finalExam != null ? m.finalExam : null
                  - const feMax = m.finalExamMax || null
                  - const pct = fe !== null && feMax ? ((fe/feMax)*100) : null
                  - const passed = pct !== null && pct >= 40
                  tr
                    td.subject-cell #{m.subject ? m.subject.name : '-'}
                    td
                      strong #{fe !== null ? fe : '—'}
                    td #{feMax ? feMax : '—'}
                    td #{pct !== null ? pct.toFixed(1)+'%' : '—'}
                    td
                      if fe !== null && feMax
                        span(class=`pf-badge ${passed?'pf-pass':'pf-fail'}`) #{passed ? 'Pass' : 'Fail'}
                      else
                        | —
              else
                tr
                  td(colspan=5, style='text-align:center;padding:1rem;color:#64748b') No final exam marks recorded.
          .exam-key
            h4 Pass Threshold: ≥ 40% of set max mark per subject

      if marks.length
        .final-summary
          - const feMarks = marks.filter(m => m.finalExam != null)
          - const passCount = isPrimary ? feMarks.filter(m => m.finalExam >= 21).length : feMarks.filter(m => m.finalExamMax && (m.finalExam/m.finalExamMax)*100 >= 40).length
          .summary-stat
            span.summary-label Subjects Sat:
            span.summary-val #{feMarks.length}
          .summary-stat
            span.summary-label Passed:
            span.summary-val.text-success #{passCount}
          .summary-stat
            span.summary-label Failed:
            span.summary-val.text-danger #{feMarks.length - passCount}

      if reportComment && reportComment.comment
        .class-teacher-comment
          h4
            i.fas.fa-comment-alt
            |  Class Teacher's Comment
          p.comment-text #{reportComment.comment}

      .report-card-footer
        .signature-area
          .sig-box
            p ___________________________
            p Class Teacher
          .sig-box
            p ___________________________
            p Head Teacher

      //- .print-date Generated: #{new Date().toLocaleDateString()}
