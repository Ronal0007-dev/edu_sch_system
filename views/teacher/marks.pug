extends ../partials/teacher-layout

block body
  .filter-bar
    form.filter-form#marksForm(method='GET', action='/teacher/marks')
      .form-row
        .form-group
          label
            span.step-badge 1
            | Department
          select(name='deptId', id='deptSelect', required)
            option(value='') Choose department
            each dept in uniqueDepts
              option(value=dept.id, selected=selectedDeptId==dept.id.toString()) #{dept.name} (#{dept.code})
        .form-group
          label
            span.step-badge 2
            | Class
          select(name='classId', id='classSelect', required)
            option(value='') — select department first —
            if selectedClass
              option(value=selectedClass.id, selected=true) #{selectedClass.name}
        .form-group
          label
            span.step-badge 3
            | Subject
          select(name='subjectId', id='subjectSelect', required)
            option(value='') — select class first —
            if selectedSubject
              option(value=selectedSubject.id, selected=true) #{selectedSubject.name}
        .form-group
          label Term
          if openTerms && openTerms.length
            select(name='term')
              each t in openTerms
                option(value=t.name, selected=term===t.name) #{t.name}
          else
            select(name='term', disabled)
              option No open terms available
            .form-hint
              i.fas.fa-lock
              span All terms are currently closed. Admin must open a term.
        .form-group
          label Academic Year
          select(name='year')
            if currentYear
              option(value=currentYear.name, selected=year===currentYear.name) #{currentYear.name} (Current)
            option(value='2024/2025', selected=year==='2024/2025') 2024/2025
            option(value='2025/2026', selected=year==='2025/2026') 2025/2026
        button.btn.btn-primary(type='submit')
          i.fas.fa-filter
          span Load

  if selectedSubject && selectedClass && students.length
    - const isPrimary = deptCode === 'Primary' || deptCode === 'EYC'
    - const isSecondary = deptCode === 'Secondary'

    //- ── SECTION 1: Continuous Assessment ───────────────────────────────────
    .section-title
      i.fas.fa-pen-alt
      if isArtDesign
        span Art & Design (Summation) — #{selectedSubject.name} | #{selectedClass.name} | #{term}
        span.exam-max-badge Out of #{ART_MAX}
      else
        span Continuous Assessment — #{selectedSubject.name} | #{selectedClass.name} | #{term}
      .section-dept-badge(class=`dept-${deptCode ? deptCode.toLowerCase() : ''}`) #{deptCode}

    if isArtDesign
      .marks-info-bar
        .info-item
          span.info-label Mode
          span.info-val Summation (H/W + G/W + QZ + C/W + U/T) — NO weighting or averaging
        .info-item
          span.info-label Out of
          span.info-val #{ART_MAX} marks
        .info-item
          span.info-label Pass threshold
          span.info-val ≥ #{Math.ceil(ART_MAX * 0.4)} / #{ART_MAX} (40%)
    else
      .marks-info-bar
        .info-item
          span.info-label Grading
          span.info-val Weighted: 10%H/W + 15%G/W + 20%QZ + 20%C/W + 35%U/T
        .info-item
          span.info-label Components
          span.info-val Each out of 100

    form(method='POST', action='/teacher/marks/save')
      input(type='hidden', name='classId', value=selectedClass.id)
      input(type='hidden', name='subjectId', value=selectedSubject.id)
      input(type='hidden', name='term', value=term)
      input(type='hidden', name='academicYear', value=year)
      input(type='hidden', name='section', value='ca')
      input(type='hidden', name='isArtDesign', value=isArtDesign ? '1' : '0')

      .marks-table-wrap
        table.marks-table.data-table
          thead
            if isArtDesign
              tr
                th Student
                th(title='Home Work') H/W
                th(title='Group Work') G/W
                th(title='Quiz') QZ
                th(title='Class Work') C/W
                th(title='Unit Test') U/T
                th Total / #{ART_MAX}
                th Result
              tr.weight-row
                th Summation →
                th +
                th +
                th +
                th +
                th +
                th = Total
                th Pass/Fail
            else
              tr
                th Student
                th(title='Home Work') H/W
                th(title='Group Work') G/W
                th(title='Quiz') QZ
                th(title='Class Work') C/W
                th(title='Unit Test') U/T
                th Method
                th CA Total
                th Grade
              tr.weight-row
                th Weights →
                th 10%
                th 15%
                th 20%
                th 20%
                th 35%
                th —
                th 100%
                th —
          tbody
            each student in students
              - const existing = existingMarks[student.id]
              tr(data-student=student.id)
                td
                  .student-mini
                    .mini-avatar #{student.fullName.charAt(0)}
                    div
                      strong #{student.fullName}
                      if student.stream
                        small #{student.stream.name}
                td
                  input.mark-input.art-input(type='number', min=0, max=100, step=0.5, name=`hw_${student.id}`, value=existing ? existing.homework : '', placeholder='0')
                td
                  input.mark-input.art-input(type='number', min=0, max=100, step=0.5, name=`gw_${student.id}`, value=existing ? existing.groupWork : '', placeholder='0')
                td
                  input.mark-input.art-input(type='number', min=0, max=100, step=0.5, name=`qz_${student.id}`, value=existing ? existing.quiz : '', placeholder='0')
                td
                  input.mark-input.art-input(type='number', min=0, max=100, step=0.5, name=`cw_${student.id}`, value=existing ? existing.classWork : '', placeholder='0')
                td
                  input.mark-input.art-input(type='number', min=0, max=100, step=0.5, name=`ut_${student.id}`, value=existing ? existing.unitTest : '', placeholder='0')
                if isArtDesign
                  td
                    span.total-display(data-sid=student.id)
                      if existing && existing.totalScore != null
                        | #{existing.totalScore}
                      else
                        | —
                    span(style='color:var(--text-muted)') &nbsp;/ #{ART_MAX}
                  td
                    span.grade-display(data-sid=student.id, class=existing ? (existing.grade==='Pass'?'pf-badge pf-pass':'pf-badge pf-fail') : '')
                      | #{existing && existing.grade ? existing.grade : '—'}
                else
                  td
                    select.method-select(name=`method_${student.id}`)
                      option(value='weighted', selected=!existing||existing.gradingMethod==='weighted') Weighted
                      option(value='unweighted', selected=existing&&existing.gradingMethod==='unweighted') Unweighted
                  td
                    span.total-display(data-sid=student.id) #{existing && existing.totalScore != null ? existing.totalScore.toFixed(1) : '—'}
                  td
                    span.grade-display(class=existing ? `grade-badge grade-${existing.grade}` : '', data-sid=student.id) #{existing && existing.grade ? existing.grade : '—'}

      .form-actions
        button.btn.btn-primary.btn-lg(type='submit')
          i.fas.fa-save
          if isArtDesign
            span Save Art & Design Marks
          else
            span Save CA Marks

    //- ── SECTION 2: Final Examination ────────────────────────────────────────
    .section-title.section-exam
      i.fas.fa-file-alt
      span Final Examination — #{selectedSubject.name} | #{selectedClass.name} | #{term}
      if isPrimary
        span.exam-max-badge Out of 50
      else if isSecondary
        span.exam-max-badge Out of (set per student below)

    if isPrimary
      .marks-info-bar
        .info-item
          span.info-label Scale
          span.info-val 0 Unclassified | 1-10 Basic | 11-20 Aspiring | 21-30 Good | 31-40 High | 41-50 Outstanding
        .info-item
          span.info-label Pass
          span.info-val ≥ 21

    else if isSecondary
      .marks-info-bar
        .info-item
          span.info-label Scale
          span.info-val Teacher sets max mark per subject below
        .info-item
          span.info-label Pass
          span.info-val ≥ 40% of max mark

    form(method='POST', action='/teacher/marks/save')
      input(type='hidden', name='classId', value=selectedClass.id)
      input(type='hidden', name='subjectId', value=selectedSubject.id)
      input(type='hidden', name='term', value=term)
      input(type='hidden', name='academicYear', value=year)
      input(type='hidden', name='section', value='fe')

      .marks-table-wrap
        table.marks-table.data-table
          thead
            tr
              th Student
              if isPrimary
                th Final Exam Score (out of 50)
                th Classification
              else
                th Final Exam Score
                th Max Mark (set once)
                th % Score
                th Pass/Fail
          tbody
            each student in students
              - const existing = existingMarks[student.id]
              - const feScore = existing ? existing.finalExam : null
              - const feMax = existing ? existing.finalExamMax : null
              tr
                td
                  .student-mini
                    .mini-avatar #{student.fullName.charAt(0)}
                    div
                      strong #{student.fullName}
                      if student.stream
                        small #{student.stream.name}
                if isPrimary
                  td
                    input.mark-input.fe-input(
                      type='number', min=0, max=50, step=0.5,
                      name=`fe_${student.id}`,
                      value=feScore != null ? feScore : '',
                      placeholder='0–50',
                      data-primary='1'
                    )
                  td
                    span.fe-class-display(data-sid=student.id)
                      if feScore != null
                        - const pg = feScore===0?'Unclassified':feScore<=10?'Basic':feScore<=20?'Aspiring':feScore<=30?'Good':feScore<=40?'High':'Outstanding'
                        span(class=`prim-grade prim-${pg.toLowerCase()}`) #{pg}
                      else
                        | —
                else
                  td
                    input.mark-input.fe-input(
                      type='number', min=0, step=0.5,
                      name=`fe_${student.id}`,
                      value=feScore != null ? feScore : '',
                      placeholder='Score'
                    )
                  td
                    input.mark-input.fe-max-input(
                      type='number', min=1, step=1,
                      name=`femax_${student.id}`,
                      value=feMax ? feMax : '',
                      placeholder='Max'
                    )
                  td
                    span.fe-pct-display(data-sid=student.id)
                      if feScore != null && feMax
                        | #{((feScore/feMax)*100).toFixed(1)}%
                      else
                        | —
                  td
                    span.fe-pass-display(data-sid=student.id)
                      if feScore != null && feMax
                        - const passed = (feScore/feMax)*100 >= 40
                        span(class=`pf-badge ${passed?'pf-pass':'pf-fail'}`) #{passed ? 'Pass' : 'Fail'}
                      else
                        | —

      .form-actions.sticky-actions
        button.btn.btn-primary.btn-lg(type='submit')
          i.fas.fa-save
          span Save Final Exam Marks

  else if selectedSubject && selectedClass && students.length === 0
    .empty-state
      i.fas.fa-user-slash
      p No students in this class.
  else
    .empty-state
      i.fas.fa-hand-pointer
      p Select a subject and class above to enter marks.

  script.
    // Cascade: Dept → Class → Subject
    // cascadeMap[deptId][classId] = { cls, subjects: [{id, name}] }
    const cascadeMap = !{JSON.stringify(cascadeMap)};
    const deptSel  = document.getElementById('deptSelect');
    const classSel = document.getElementById('classSelect');
    const subjSel  = document.getElementById('subjectSelect');
    const savedDept = '!{selectedDeptId}';
    const savedCls  = '!{selectedClassId}';
    const savedSubj = '!{selectedSubjectId}';

    function updateClasses() {
      const did = deptSel.value;
      const classEntries = cascadeMap[did] ? Object.values(cascadeMap[did]) : [];
      classSel.innerHTML = '<option value="">— select class —</option>';
      classEntries.forEach(function(entry) {
        const opt = document.createElement('option');
        opt.value = entry.cls.id;
        opt.textContent = entry.cls.name;
        if (String(entry.cls.id) === savedCls) opt.selected = true;
        classSel.appendChild(opt);
      });
      updateSubjects();
    }

    function updateSubjects() {
      const did = deptSel.value;
      const cid = classSel.value;
      const entry = cascadeMap[did] && cascadeMap[did][cid];
      const subjects = entry ? entry.subjects : [];
      subjSel.innerHTML = '<option value="">— select subject —</option>';
      subjects.forEach(function(s) {
        const opt = document.createElement('option');
        opt.value = s.id;
        opt.textContent = s.name;
        if (String(s.id) === savedSubj) opt.selected = true;
        subjSel.appendChild(opt);
      });
    }

    deptSel.addEventListener('change', updateClasses);
    classSel.addEventListener('change', updateSubjects);

    // Init on page load (restore saved selections)
    if (deptSel.value) updateClasses();

    // ── Live CA / Art & Design calculation ──────────────────────────────────
    var isArtMode = !{isArtDesign ? 'true' : 'false'};
    var ART_MAX   = !{ART_MAX};
    var ART_PASS  = Math.ceil(ART_MAX * 0.4); // 29

    function getGrade(s) { return s>=90?'A':s>=80?'B':s>=70?'C':s>=60?'D':'F'; }

    function calcCA(row, method) {
      var g = function(n) {
        var el = row.querySelector('[name^="' + n + '_"]');
        return el ? (parseFloat(el.value) || 0) : 0;
      };
      var hw=g('hw'), gw=g('gw'), qz=g('qz'), cw=g('cw'), ut=g('ut');
      if (isArtMode) return hw + gw + qz + cw + ut;
      return method==='weighted' ? hw*.10+gw*.15+qz*.20+cw*.20+ut*.35 : (hw+gw+qz+cw+ut)/5;
    }

    document.querySelectorAll('.marks-table tbody tr').forEach(function(row) {
      var sid = row.dataset.student;
      if (!sid) return;
      var totalEl = row.querySelector('.total-display[data-sid="' + sid + '"]');
      var gradeEl = row.querySelector('.grade-display[data-sid="' + sid + '"]');

      function update() {
        var method = row.querySelector('.method-select') ? row.querySelector('.method-select').value : 'weighted';
        var total  = calcCA(row, method);

        if (isArtMode) {
          var passed = total >= ART_PASS;
          if (totalEl) totalEl.textContent = total.toFixed(1);
          if (gradeEl) {
            gradeEl.textContent = passed ? 'Pass' : 'Fail';
            gradeEl.className = passed ? 'pf-badge pf-pass' : 'pf-badge pf-fail';
          }
        } else {
          var grade = getGrade(total);
          if (totalEl) totalEl.textContent = total.toFixed(1);
          if (gradeEl) { gradeEl.textContent = grade; gradeEl.className = 'grade-badge grade-' + grade; }
        }
      }

      row.querySelectorAll('.mark-input, .method-select').forEach(function(el) {
        el.addEventListener('input', update);
      });
    });

    // Live Primary FE classification
    const primGradeLabel = s => s===0?'Unclassified':s<=10?'Basic':s<=20?'Aspiring':s<=30?'Good':s<=40?'High':'Outstanding';
    document.querySelectorAll('.fe-input[data-primary]').forEach(inp => {
      inp.addEventListener('input', function() {
        const row = this.closest('tr');
        const sid = row ? row.querySelector('.mini-avatar') ? row.querySelector('[name^="fe_"]').name.replace('fe_','') : null : null;
        const dispEl = sid ? document.querySelector('.fe-class-display[data-sid="' + sid + '"]') : null;
        if (dispEl) {
          const score = parseFloat(this.value) || 0;
          const label = primGradeLabel(score);
          const cls = 'prim-grade prim-' + label.toLowerCase();
          dispEl.innerHTML = '<span class="' + cls + '">' + label + '</span>';
        }
      });
    });

    // Live Secondary FE pass/fail
    document.querySelectorAll('.fe-input:not([data-primary]), .fe-max-input').forEach(inp => {
      inp.addEventListener('input', function() {
        const row = this.closest('tr');
        if (!row) return;
        const feInp = row.querySelector('.fe-input');
        const maxInp = row.querySelector('.fe-max-input');
        const nameAttr = feInp ? feInp.name : '';
        const sid = nameAttr.replace('fe_', '');
        const score = parseFloat(feInp ? feInp.value : 0) || 0;
        const max = parseFloat(maxInp ? maxInp.value : 0) || 0;
        const pctEl = document.querySelector('.fe-pct-display[data-sid="' + sid + '"]');
        const passEl = document.querySelector('.fe-pass-display[data-sid="' + sid + '"]');
        if (max > 0) {
          const pct = (score / max) * 100;
          if (pctEl) pctEl.textContent = pct.toFixed(1) + '%';
          if (passEl) {
            const passed = pct >= 40;
            passEl.innerHTML = '<span class="pf-badge ' + (passed?'pf-pass':'pf-fail') + '">' + (passed?'Pass':'Fail') + '</span>';
          }
        }
      });
    });
